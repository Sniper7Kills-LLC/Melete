<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX installer template for Melete (Phase 7.5, #43).

  Consumed by `cargo wix`. Produces an unsigned MSI under
  `target/wix/`. Signing with an EV cert is Phase B.

  Component layout: the melete-app.exe plus every DLL gvsbuild
  drops into the build's `bin/` dir gets harvested into a single
  feature so MSI Repair / Uninstall has a stable component list.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="Melete"
    Language="1033"
    Version="$(var.Version)"
    Manufacturer="Sniper7Kills LLC"
    UpgradeCode="b5e7e2c6-1f3e-4ad0-9c5e-3a1f1b2c1d0e">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perUser"
      Description="Melete — Personal stylus-friendly notebook, journal & planner"
      Comments="(c) 2026 Sniper7Kills LLC. AGPL-3.0-or-later." />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Melete is already installed."
      Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MeleteApp" Title="Melete" Level="1">
      <ComponentGroupRef Id="MeleteAppComponents" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="APPLICATIONFOLDER" Name="Melete">
          <Directory Id="BinFolder" Name="bin" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="StartMenuFolder" Name="Melete">
          <Component Id="StartMenuShortcut" Guid="*">
            <Shortcut
              Id="MeleteStartShortcut"
              Name="Melete"
              Description="Personal stylus-friendly notebook, journal &amp; planner"
              Target="[BinFolder]melete-app.exe"
              WorkingDirectory="BinFolder" />
            <RemoveFolder Id="StartMenuFolder" On="uninstall" />
            <RegistryValue
              Root="HKCU"
              Key="Software\Sniper7Kills LLC\Melete"
              Name="installed"
              Type="integer"
              Value="1"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>
  </Product>
</Wix>
