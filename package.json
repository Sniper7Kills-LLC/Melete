    "@types/node": "^22.19.18",
    "aws-cdk": "^2.158.0",
    "aws-cdk-lib": "^2.158.0",
    "constructs": "^10.4.2",
    "esbuild": "^0.24.0",
    "toml": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.687.0",
